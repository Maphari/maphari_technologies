generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id                     String                        @id @default(uuid())
  name                   String
  status                 String                        @default("ACTIVE")
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  priority               String                        @default("MEDIUM")
  tier                   String                        @default("STARTER")
  timezone               String?
  billingEmail           String?
  ownerName              String?
  contractStartAt        DateTime?
  contractRenewalAt      DateTime?
  slaTier                String                        @default("STANDARD")
  slaResponseHours       Int                           @default(24)
  notes                  String?
  appointments           Appointment[]
  brandAssets            BrandAsset[]
  activities             ClientActivity[]
  contacts               ClientContact[]
  contracts              ClientContract[]
  healthScores           ClientHealthScore[]
  healthSignals          ClientHealthSignal[]
  interventions          ClientIntervention[]
  onboardingRecords      ClientOnboardingRecord[]
  profile                ClientProfile?
  statusHistory          ClientStatusHistory[]
  communicationLogs      CommunicationLog[]
  leads                  Lead[]
  milestoneApprovals     MilestoneApproval[]
  offboardingTasks       OffboardingTask[]
  blockers               ProjectBlocker[]
  changeRequests         ProjectChangeRequest[]
  collaborationNotes     ProjectCollaborationNote[]
  collaborators          ProjectTaskCollaborator[]
  integrationConnections ClientIntegrationConnection[]
  integrationRequests    ClientIntegrationRequest[]
  timeEntries            ProjectTimeEntry[]
  workSessions           ProjectWorkSession[]
  projects               Project[]
  proposals              Proposal[]
  satisfactionSurveys    SatisfactionSurvey[]
  slaRecords             SLARecord[]
  supportTickets         SupportTicket[]
  surveyTokens           SurveyToken[]

  @@index([status])
  @@index([priority])
  @@index([tier])
  @@index([contractRenewalAt])
  @@map("clients")
}

model ClientContact {
  id              String   @id @default(uuid())
  clientId        String
  name            String
  email           String
  phone           String?
  role            String?
  isPrimary       Boolean  @default(false)
  canManageAccess Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([email])
  @@map("client_contacts")
}

model ClientActivity {
  id        String   @id @default(uuid())
  clientId  String
  type      String
  message   String
  actorId   String?
  actorRole String?
  metadata  String?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("client_activities")
}

model ClientStatusHistory {
  id         String   @id @default(uuid())
  clientId   String
  fromStatus String?
  toStatus   String
  reason     String?
  actorId    String?
  actorRole  String?
  changedAt  DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, changedAt])
  @@map("client_status_history")
}

model Project {
  id                 String                     @id @default(uuid())
  clientId           String
  name               String
  description        String?
  status             String                     @default("PLANNING")
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  ownerName          String?
  priority           String                     @default("MEDIUM")
  riskLevel          String                     @default("LOW")
  startAt            DateTime?
  dueAt              DateTime?
  completedAt        DateTime?
  budgetCents        BigInt                     @default(0)
  progressPercent    Int                        @default(0)
  slaDueAt           DateTime?
  referenceCode      String?                    @unique(map: "projects_referencecode_key")
  designReviews      DesignReview[]
  eftVerification    EftVerification?
  handoverRecords    HandoverRecord[]
  milestoneApprovals MilestoneApproval[]
  contracts          ClientContract[]
  proposals          Proposal[]
  activities         ProjectActivity[]
  blockers           ProjectBlocker[]
  brief              ProjectBrief?
  changeRequests     ProjectChangeRequest[]
  closeoutReports    ProjectCloseoutReport[]
  collaborationNotes ProjectCollaborationNote[]
  decisions          ProjectDecision[]
  deliverables       ProjectDeliverable[]
  blocking           ProjectDependency[]        @relation("ProjectBlocking")
  dependencies       ProjectDependency[]        @relation("ProjectDependencies")
  milestones         ProjectMilestone[]
  phases             ProjectPhase[]
  risks              ProjectRisk[]
  signOffs           ProjectSignOff[]
  sprints            ProjectSprint[]
  collaborators      ProjectTaskCollaborator[]
  tasks              ProjectTask[]
  timeEntries        ProjectTimeEntry[]
  workSessions       ProjectWorkSession[]
  client             Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([status])
  @@index([priority])
  @@index([riskLevel])
  @@index([dueAt])
  @@map("projects")
}

model ProjectMilestone {
  id              String               @id @default(uuid())
  projectId       String
  title           String
  status          String               @default("PENDING")
  dueAt           DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  fileId          String?              @db.Uuid
  progressPercent Int                  @default(0)
  tags            String?
  approval        MilestoneApproval?
  deliverables    ProjectDeliverable[]
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status])
  @@map("project_milestones")
}

model MilestoneApproval {
  id          String           @id @default(uuid())
  milestoneId String           @unique
  projectId   String
  clientId    String
  status      String           @default("PENDING")
  comment     String?
  decidedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  client      Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  milestone   ProjectMilestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
  @@index([status])
  @@map("milestone_approvals")
}

model ConversationNote {
  id             String   @id @default(uuid())
  conversationId String
  authorId       String?
  authorRole     String?
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

model ConversationEscalation {
  id             String    @id @default(uuid())
  conversationId String
  messageId      String?
  severity       String    @default("MEDIUM")
  status         String    @default("OPEN")
  reason         String
  ownerAdminId   String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([conversationId, createdAt])
  @@index([status])
  @@map("conversation_escalations")
}

model ProjectTask {
  id              String                    @id @default(uuid())
  projectId       String
  title           String
  assigneeName    String?
  externalLinks   Json?
  status          String                    @default("TODO")
  dueAt           DateTime?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  blockedAt       DateTime?
  estimateMinutes Int?
  priority        String                    @default("MEDIUM")
  progressPercent Int                       @default(0)
  sprintId        String?
  storyPoints     Int?
  collaborators   ProjectTaskCollaborator[]
  project         Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint          ProjectSprint?            @relation(fields: [sprintId], references: [id])
  workSessions    ProjectWorkSession[]

  @@index([projectId, createdAt])
  @@index([status])
  @@index([sprintId])
  @@map("project_tasks")
}

model ProjectTaskCollaborator {
  id                String      @id @default(uuid())
  projectId         String
  taskId            String
  clientId          String
  staffUserId       String?     @db.Uuid
  staffName         String
  role              String?     @default("CONTRIBUTOR")
  allocationPercent Int         @default(0)
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  client            Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project           Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task              ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
  @@index([clientId, createdAt])
  @@map("project_task_collaborators")
}

model ProjectCollaborationNote {
  id         String   @id @default(uuid())
  projectId  String
  clientId   String
  authorId   String?  @db.Uuid
  authorRole String?
  authorName String?
  visibility String   @default("INTERNAL")
  workstream String?
  message    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([clientId, createdAt])
  @@index([visibility, createdAt])
  @@map("project_collaboration_notes")
}

model ProjectWorkSession {
  id         String       @id @default(uuid())
  projectId  String
  clientId   String
  taskId     String?
  memberId   String?      @db.Uuid
  memberName String
  memberRole String       @default("STAFF")
  workstream String?
  status     String       @default("ACTIVE")
  startedAt  DateTime     @default(now())
  endedAt    DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task       ProjectTask? @relation(fields: [taskId], references: [id])

  @@index([projectId, createdAt])
  @@index([clientId, createdAt])
  @@index([status, startedAt])
  @@map("project_work_sessions")
}

model ProjectTimeEntry {
  id              String        @id @default(uuid())
  projectId       String
  clientId        String
  staffUserId     String?       @db.Uuid
  staffName       String?
  taskLabel       String
  minutes         Int
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  phaseId         String?
  status          String        @default("DRAFT")
  submittedAt     DateTime?
  submittedWeek   String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  phase           ProjectPhase? @relation(fields: [phaseId], references: [id])
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
  @@index([phaseId])
  @@index([status])
  @@index([staffUserId, submittedWeek])
  @@map("project_time_entries")
}

model ProjectDependency {
  id                 String   @id @default(uuid())
  projectId          String
  blockedByProjectId String
  type               String   @default("BLOCKS")
  createdAt          DateTime @default(now())
  blockedByProject   Project  @relation("ProjectBlocking", fields: [blockedByProjectId], references: [id], onDelete: Cascade)
  project            Project  @relation("ProjectDependencies", fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([blockedByProjectId])
  @@map("project_dependencies")
}

model ProjectActivity {
  id        String   @id @default(uuid())
  projectId String
  clientId  String
  type      String
  details   String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([clientId, createdAt])
  @@map("project_activities")
}

model ProjectBlocker {
  id          String    @id @default(uuid())
  projectId   String
  clientId    String
  title       String
  description String?
  severity    String    @default("MEDIUM")
  status      String    @default("OPEN")
  ownerRole   String?
  ownerName   String?
  etaAt       DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, severity])
  @@map("project_blockers")
}

model ProjectChangeRequest {
  id                  String    @id @default(uuid())
  projectId           String
  clientId            String
  title               String
  description         String?
  reason              String?
  impactSummary       String?
  status              String    @default("SUBMITTED")
  requestedByRole     String?
  requestedByName     String?
  requestedAt         DateTime  @default(now())
  estimatedHours      Float?
  estimatedCostCents  BigInt?
  staffAssessment     String?
  estimatedAt         DateTime?
  estimatedByRole     String?
  estimatedByName     String?
  adminDecisionNote   String?
  adminDecidedAt      DateTime?
  adminDecidedByRole  String?
  adminDecidedByName  String?
  clientDecisionNote  String?
  clientDecidedAt     DateTime?
  clientDecidedByRole String?
  clientDecidedByName String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@map("project_change_requests")
}

model Lead {
  id             String         @id @default(uuid())
  clientId       String?
  title          String
  source         String?
  status         String         @default("NEW")
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  ownerName      String?
  nextFollowUpAt DateTime?
  lostReason     String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  company        String?
  activities     LeadActivity[]
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([status])
  @@index([nextFollowUpAt])
  @@index([contactEmail])
  @@index([contactPhone])
  @@map("leads")
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  clientId  String
  type      String
  details   String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([clientId, createdAt])
  @@map("lead_activities")
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId])
  @@map("user_preferences")
}

model ClientIntegrationRequest {
  id                String    @id @default(uuid())
  clientId          String
  provider          String
  status            String    @default("REQUESTED")
  requestedByUserId String?
  assignedToUserId  String?
  notes             String?
  completedByUserId String?
  rejectedReason    String?
  priority          String?
  requestedVia      String?
  sourceContext     Json?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([clientId, provider, status])
  @@index([status, assignedToUserId, createdAt])
  @@map("client_integration_requests")
}

model IntegrationProvider {
  id                   String                        @id @default(uuid())
  key                  String                        @unique
  label                String
  description          String
  category             String
  kind                 String
  availabilityStatus   String                        @default("active")
  iconKey              String
  isClientVisible      Boolean                       @default(true)
  isRequestEnabled     Boolean                       @default(false)
  supportsDisconnect   Boolean                       @default(false)
  supportsReconnect    Boolean                       @default(false)
  supportsHealthChecks Boolean                       @default(false)
  sortOrder            Int                           @default(0)
  launchStage          String?
  helpUrl              String?
  setupGuideUrl        String?
  metadata             Json?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  connections          ClientIntegrationConnection[]

  @@index([isClientVisible, sortOrder])
  @@index([availabilityStatus, sortOrder])
  @@map("integration_providers")
}

model ClientIntegrationConnection {
  id                      String                 @id @default(uuid())
  clientId                String
  providerId              String
  providerKey             String
  status                  String
  connectionType          String
  connectedByUserId       String?
  connectedByContactEmail String?
  assignedOwnerUserId     String?
  connectedAt             DateTime?
  disconnectedAt          DateTime?
  lastCheckedAt           DateTime?
  lastSyncedAt            DateTime?
  lastSuccessfulSyncAt    DateTime?
  lastErrorCode           String?
  lastErrorMessage        String?
  healthStatus            String?
  configurationSummary    Json?
  externalAccountId       String?
  externalAccountLabel    String?
  metadata                Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  client                  Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider                IntegrationProvider    @relation(fields: [providerId], references: [id], onDelete: Restrict)
  syncEvents              IntegrationSyncEvent[]

  @@unique([clientId, providerKey])
  @@index([clientId, status])
  @@index([providerKey, status])
  @@index([healthStatus, updatedAt])
  @@map("client_integration_connections")
}

model IntegrationSyncEvent {
  id             String                      @id @default(uuid())
  connectionId   String
  clientId       String
  taskId         String?
  providerKey    String
  idempotencyKey String?
  status         String
  startedAt      DateTime
  finishedAt     DateTime?
  durationMs     Int?
  summary        String?
  errorCode      String?
  errorMessage   String?
  details        Json?
  createdAt      DateTime                    @default(now())
  connection     ClientIntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@index([clientId, providerKey, createdAt])
  @@index([taskId, createdAt])
  @@index([taskId, providerKey, idempotencyKey])
  @@map("integration_sync_events")
}

model ProjectDeliverable {
  id             String            @id @default(uuid())
  projectId      String
  milestoneId    String?
  name           String
  ownerName      String?
  status         String            @default("NOT_STARTED")
  dueAt          DateTime?
  deliveredAt    DateTime?
  clientFeedback String?
  reviewedAt     DateTime?
  reviewedByName String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  milestone      ProjectMilestone? @relation(fields: [milestoneId], references: [id])
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status])
  @@map("project_deliverables")
}

model ProjectRisk {
  id         String   @id @default(uuid())
  projectId  String
  clientId   String
  name       String
  detail     String?
  likelihood String   @default("MEDIUM")
  impact     String   @default("MEDIUM")
  mitigation String?
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status])
  @@map("project_risks")
}

model ProjectDecision {
  id            String    @id @default(uuid())
  projectId     String
  clientId      String
  title         String
  context       String?
  decidedByName String?
  decidedByRole String?
  decidedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_decisions")
}

model ProjectSprint {
  id              String        @id @default(uuid())
  projectId       String
  clientId        String
  name            String
  ownerName       String?
  startAt         DateTime?
  endAt           DateTime?
  progressPercent Int           @default(0)
  totalTasks      Int           @default(0)
  completedTasks  Int           @default(0)
  overdueTasks    Int           @default(0)
  status          String        @default("ACTIVE")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks           ProjectTask[]

  @@index([projectId, createdAt])
  @@index([status])
  @@map("project_sprints")
}

model ProjectSignOff {
  id           String    @id @default(uuid())
  projectId    String
  clientId     String
  name         String
  description  String?
  status       String    @default("NOT_READY")
  signedAt     DateTime?
  signedByName String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([status])
  @@map("project_sign_offs")
}

model ProjectPhase {
  id            String             @id @default(uuid())
  projectId     String
  clientId      String
  name          String
  budgetedHours Float              @default(0)
  loggedHours   Float              @default(0)
  color         String?
  sortOrder     Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  project       Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timeEntries   ProjectTimeEntry[]

  @@index([projectId, sortOrder])
  @@map("project_phases")
}

model ProjectBrief {
  id         String   @id @default(uuid())
  projectId  String   @unique
  clientId   String
  objectives String
  inScope    String
  outOfScope String
  contacts   String
  status     String   @default("ACTIVE")
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("project_briefs")
}

model ClientHealthScore {
  id                 String    @id @default(uuid())
  clientId           String
  score              Int
  trend              String    @default("STABLE")
  trendValue         Int       @default(0)
  sentiment          String    @default("NEUTRAL")
  lastTouched        DateTime?
  overdueTasks       Int       @default(0)
  unreadMessages     Int       @default(0)
  milestoneDelayDays Int       @default(0)
  retainerBurnPct    Int       @default(0)
  invoiceStatus      String    @default("PENDING")
  recordedAt         DateTime  @default(now())
  client             Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, recordedAt])
  @@map("client_health_scores")
}

model ClientHealthSignal {
  id        String   @id @default(uuid())
  clientId  String
  type      String
  text      String
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("client_health_signals")
}

model ClientIntervention {
  id          String    @id @default(uuid())
  clientId    String
  type        String
  description String?
  status      String    @default("OPEN")
  assignedTo  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@map("client_interventions")
}

model SatisfactionSurvey {
  id          String                 @id @default(uuid())
  clientId    String
  periodStart DateTime
  periodEnd   DateTime
  npsScore    Int?
  csatScore   Int?
  status      String                 @default("PENDING")
  completedAt DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  responses   SatisfactionResponse[]
  client      Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tokens      SurveyToken[]

  @@index([clientId, periodStart])
  @@map("satisfaction_surveys")
}

model SatisfactionResponse {
  id        String             @id @default(uuid())
  surveyId  String
  question  String
  answer    String
  createdAt DateTime           @default(now())
  comment   String?
  survey    SatisfactionSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@map("satisfaction_responses")
}

model SurveyToken {
  id        String             @id @default(uuid())
  token     String             @unique
  surveyId  String
  clientId  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime           @default(now())
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
