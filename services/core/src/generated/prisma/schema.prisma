  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("market_rates")
}

model EntityComment {
  id         String   @id @default(uuid()) @db.VarChar(36)
  clientId   String   @db.VarChar(36)
  entityType String   @db.VarChar(64)
  entityId   String   @db.VarChar(36)
  authorName String   @db.VarChar(128)
  authorRole String   @default("CLIENT") @db.VarChar(32)
  message    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clientId, entityType, entityId, createdAt])
  @@map("entity_comments")
}

model Crisis {
  id          String    @id @default(cuid())
  title       String
  severity    String
  status      String
  description String?
  ownerId     String?
  clientId    String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, severity])
  @@index([createdAt])
  @@map("crises")
}

model ComplianceRecord {
  id        String   @id @default(cuid())
  area      String
  status    String
  riskLevel String
  lastAudit DateTime
  nextAudit DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, riskLevel])
  @@map("compliance_records")
}

model DataRetentionPolicy {
  id          String    @id @default(cuid())
  dataType    String
  retainYears Int
  lastPurge   DateTime?
  nextPurge   DateTime
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@map("data_retention_policies")
}

model FyChecklistItem {
  id         String    @id @default(cuid())
  fiscalYear String
  label      String
  category   String
  done       Boolean   @default(false)
  doneAt     DateTime?
  doneBy     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([fiscalYear, label])
  @@index([fiscalYear])
  @@map("fy_checklist_items")
}

model StaffGoal {
  id          String   @id @default(cuid())
  staffUserId String
  title       String
  description String?
  targetDate  DateTime
  progress    Int      @default(0)
  status      String   @default("ACTIVE")
  quarter     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([staffUserId])
  @@index([staffUserId, quarter])
}

model DeliverableAnnotation {
  id            String    @id @default(cuid())
  deliverableId String
  clientId      String
  comment       String
  pageNumber    Int?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([deliverableId])
  @@map("deliverable_annotations")
}

model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  phases      Json
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("project_templates")
}

model ForumThread {
  id         String      @id @default(uuid())
  category   String
  title      String      @db.VarChar(200)
  authorId   String
  anonAlias  String      @db.VarChar(60)
  isPinned   Boolean     @default(false)
  isLocked   Boolean     @default(false)
  isApproved Boolean     @default(false)
  isRejected Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  posts      ForumPost[]

  @@index([category, isApproved])
  @@index([isApproved, createdAt])
  @@map("forum_threads")
}

model ForumPost {
  id         String      @id @default(uuid())
  threadId   String
  authorId   String
  anonAlias  String      @db.VarChar(60)
  body       String
  isApproved Boolean     @default(false)
  isRejected Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  thread     ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, isApproved])
  @@map("forum_posts")
}

model FeatureRequest {
  id          String        @id @default(uuid())
  category    String
  title       String        @db.VarChar(200)
  description String
  authorId    String
  anonAlias   String        @db.VarChar(60)
  status      String        @default("under_review")
  voteCount   Int           @default(0)
  isApproved  Boolean       @default(false)
  isRejected  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  votes       FeatureVote[]

  @@index([category, status, isApproved])
  @@index([isApproved, voteCount])
  @@map("feature_requests")
}

model FeatureVote {
  id               String         @id @default(uuid())
  featureRequestId String
  voterId          String
  createdAt        DateTime       @default(now())
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)

  @@unique([featureRequestId, voterId])
  @@map("feature_votes")
}

model EftVerification {
  id              String                @id @default(cuid())
  projectId       String                @unique(map: "eft_verifications_projectid_key")
  clientId        String
  proofFileId     String
  proofFileName   String
  status          EftVerificationStatus @default(PENDING)
  verifiedBy      String?
  verifiedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "eft_verifications_projectid_fkey")

  @@map("eft_verifications")
}

model calendar_events {
  id         String   @id
  title      String
  startAt    DateTime
  endAt      DateTime
  type       String
  sourceId   String
  sourceType String
  roles      String[]
  clientId   String?
  staffId    String?
  createdAt  DateTime @default(now())
}

enum EftVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}
