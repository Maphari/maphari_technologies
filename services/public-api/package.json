{
  "name": "@maphari/public-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma"
  },
  "dependencies": {
    "@maphari/contracts": "workspace:*",
    "@maphari/platform": "workspace:*",
    "@prisma/client": "6.19.2",
    "fastify": "^5.6.2",
    "ioredis": "^5.9.3"
  },
  "devDependencies": {
    "prisma": "^6.19.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
