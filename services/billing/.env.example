# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/maphari_billing

# ─── Cache & Messaging ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ─── Service ──────────────────────────────────────────────────────────────────
PORT=4006

# ─── PayFast Payment Gateway ──────────────────────────────────────────────────
# NOTE: This service uses PayFast (South African gateway), NOT Stripe.
# Obtain credentials from https://www.payfast.co.za/registration/register
#
# Sandbox credentials are available at https://sandbox.payfast.co.za
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
# Optional: used to strengthen MD5 signature — set in PayFast dashboard
PAYFAST_PASSPHRASE=

# ─── Webhook / ITN ────────────────────────────────────────────────────────────
# PayFast sends ITN (Instant Transaction Notification) as POST to /payfast/itn.
# The notify_url is derived from BILLING_BASE_URL if not provided per-request.
# Signature verification uses MD5 over sorted form fields (+ passphrase if set).
BILLING_BASE_URL=http://localhost:4006

# ─── Cross-service URLs ───────────────────────────────────────────────────────
# Used to auto-confirm payment milestones in the core service after ITN.
CORE_SERVICE_URL=http://localhost:4003
# Used to build return/cancel URLs for the PayFast redirect flow.
APP_BASE_URL=http://localhost:3000

# ─── Rate Limiting (optional — defaults shown) ────────────────────────────────
SERVICE_RATE_LIMIT_PUBLIC_MAX=120
SERVICE_RATE_LIMIT_PROTECTED_MAX=240
SERVICE_RATE_LIMIT_WINDOW_MS=60000
