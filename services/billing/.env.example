# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/maphari_billing

# ─── Cache & Messaging ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# ─── Service ──────────────────────────────────────────────────────────────────
PORT=4006

# ─── PayFast Payment Gateway ──────────────────────────────────────────────────
# NOTE: This service uses PayFast (South African gateway), NOT Stripe.
# Obtain credentials from https://www.payfast.co.za/registration/register
#
# Sandbox credentials are available at https://sandbox.payfast.co.za
# These defaults match PayFast's public test account as of March 24, 2026.
PAYFAST_MERCHANT_ID=10004002
PAYFAST_MERCHANT_KEY=q1cd2rdny4a53
# Sandbox default passphrase for the public test account.
PAYFAST_PASSPHRASE=payfast

# ─── Webhook / ITN ────────────────────────────────────────────────────────────
# PayFast sends ITN (Instant Transaction Notification) as POST to /payfast/itn.
# Set BILLING_PUBLIC_BASE_URL in local dev when using a tunnel so PayFast can
# reach your machine for ITN callbacks.
BILLING_PUBLIC_BASE_URL=
# The notify_url is derived from BILLING_PUBLIC_BASE_URL or BILLING_BASE_URL.
# Signature verification uses MD5 over submitted form fields (+ passphrase if set).
BILLING_BASE_URL=http://localhost:4006

# ─── Cross-service URLs ───────────────────────────────────────────────────────
# Used to auto-confirm payment milestones in the core service after ITN.
CORE_SERVICE_URL=http://localhost:4002
# Used to queue real reminder deliveries.
NOTIFICATIONS_SERVICE_URL=http://localhost:4009
# Used to build return/cancel URLs for the PayFast redirect flow.
APP_BASE_URL=http://localhost:3000

# ─── Invoice Reminders ────────────────────────────────────────────────────────
# Scheduler cadence in milliseconds for automatic reminder scans.
INVOICE_REMINDER_SWEEP_MS=300000

# ─── Rate Limiting (optional — defaults shown) ────────────────────────────────
SERVICE_RATE_LIMIT_PUBLIC_MAX=120
SERVICE_RATE_LIMIT_PROTECTED_MAX=240
SERVICE_RATE_LIMIT_WINDOW_MS=60000
