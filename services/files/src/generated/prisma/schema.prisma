generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FileRecord {
  id             String   @id @default(uuid())
  clientId       String
  fileName       String
  storageKey     String
  mimeType       String
  sizeBytes      BigInt
  approvalStatus String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | CHANGES_REQUESTED
  versionOf      String? // id of the parent FileRecord this is a new version of
  versionNote    String? // short note from uploader about what changed
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId, createdAt])
  @@index([versionOf])
  @@map("files")
}

/// Admin Document Vault — structured metadata for uploaded company documents.
/// Documents are stored in S3 (storageKey) and tracked here with rich metadata.
/// clientId is optional: null means the document belongs to the company (admin-only).
model VaultDocument {
  id          String   @id @default(uuid())
  title       String
  category    String   @default("MISC") // CONTRACT | BRIEF | DELIVERABLE | INVOICE | ASSET | TEMPLATE | MISC
  description String?
  status      String   @default("PUBLISHED") // DRAFT | PUBLISHED | ARCHIVED
  clientId    String? // null = company-wide doc
  fileName    String
  mimeType    String
  sizeBytes   BigInt   @default(0)
  storageKey  String
  uploadedBy  String   @default("admin")
  version     Int      @default(1)
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category, status])
  @@index([clientId, createdAt])
  @@map("vault_documents")
}
