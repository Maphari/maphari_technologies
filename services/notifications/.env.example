# ══════════════════════════════════════════════════════════════════
# services/notifications — Notification Service
# Handles: EMAIL, SMS, and in-app notification delivery.
# Notifications are enqueued via NATS events from other services
# and processed by this service's job queue.
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=4009

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string for the notifications schema
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/maphari?schema=notifications_schema"

# ── NATS ──────────────────────────────────────────────────────────
# Message bus URL for receiving notification events from other services
NATS_URL="nats://localhost:4222"

# ── Email Delivery (Resend) ───────────────────────────────────────
# REQUIRED for email notifications to work.
# Get your API key at: https://resend.com/api-keys
# Free tier: 3,000 emails/month. Verify your sending domain in Resend first.
RESEND_API_KEY="re_replace-with-your-resend-api-key"
# The "from" address for all outgoing emails.
# Must use a domain you have verified in your Resend account.
# Format: "Display Name <email@yourdomain.com>"
NOTIFICATION_FROM_EMAIL="Maphari <notifications@mapharitechnologies.com>"

# ── SMS Delivery (Twilio) ─────────────────────────────────────────
# OPTIONAL. Required only if SMS notifications are enabled.
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="replace-with-your-twilio-auth-token"
# A Twilio phone number or Messaging Service SID you own
# Must be enabled for the target country (e.g. +27 for South Africa)
TWILIO_FROM_NUMBER="+27000000000"

# ── Webhook Callback Security ─────────────────────────────────────
# REQUIRED. Used to verify inbound delivery-status callbacks from providers.
# Generate a strong secret with: openssl rand -hex 32
NOTIFICATION_CALLBACK_SECRET="replace-with-long-random-secret"
NOTIFICATION_CALLBACK_RATE_LIMIT_MAX=30
NOTIFICATION_CALLBACK_RATE_LIMIT_WINDOW_MS=60000

# ── Push Notifications (Firebase Cloud Messaging) ─────────────────
# OPTIONAL. Required only if push notifications are enabled.
# Get your server key at: https://console.firebase.google.com → Project Settings → Cloud Messaging
FCM_SERVER_KEY="replace-with-your-fcm-server-key"

# ── Queue Processor Tuning ────────────────────────────────────────
# How often (ms) the background loop drains the notification queue.
# Default: 5000 (5 seconds). Lower = lower latency, higher DB load.
NOTIFICATION_POLL_INTERVAL_MS=5000
# Max jobs processed per poll tick. Default: 10.
NOTIFICATION_MAX_JOBS_PER_TICK=10

# ── Security controls ─────────────────────────────────────────────
NODE_ENV="development"
SERVICE_RATE_LIMIT_PUBLIC_MAX=120
SERVICE_RATE_LIMIT_PROTECTED_MAX=240
SERVICE_RATE_LIMIT_WINDOW_MS=60000
