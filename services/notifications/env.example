# ─────────────────────────────────────────────────────────────────────────────
# Notifications Service — Environment Variables
# Copy this file to .env and fill in the values before running the service.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (same DB as the core service, or a dedicated one)
DATABASE_URL="postgresql://user:password@localhost:5432/maphari_notifications"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Required in production. Get your key at https://resend.com/api-keys
# In development: leave empty or set to "re_replace_me" — emails will be skipped.
RESEND_API_KEY=re_replace_me

# The "From" address used for all outgoing emails.
# Must be a verified sender domain in your Resend account.
NOTIFICATION_FROM_EMAIL="Maphari <notifications@maphari.com>"

# ── SMS / WhatsApp (Twilio) ───────────────────────────────────────────────────
# Required only when sending SMS or WhatsApp notifications.
# Leave blank in development — SMS jobs will be skipped gracefully.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Phone number in E.164 format, e.g. +27100000000
TWILIO_FROM_NUMBER=+10000000000

# ── Push Notifications (Firebase Cloud Messaging) ────────────────────────────
# Required only when sending push notifications (PUSH channel).
# Leave blank in development — push jobs will be skipped gracefully.
FCM_SERVER_KEY=replace_with_your_fcm_server_key

# ── NATS Event Bus ───────────────────────────────────────────────────────────
# URL of the NATS server used for domain event subscriptions.
NATS_URL=nats://localhost:4222

# ── Server ───────────────────────────────────────────────────────────────────
PORT=4009
NODE_ENV=development

# ── Queue Tuning (optional) ───────────────────────────────────────────────────
# How often (ms) to poll the DB for ready notification jobs. Default: 5000
NOTIFICATION_POLL_INTERVAL_MS=5000
# Max jobs processed per poll tick. Default: 10
NOTIFICATION_MAX_JOBS_PER_TICK=10
