# ══════════════════════════════════════════════════════════════════
# services/auth — Authentication Service
# Handles: user registration, login, JWT issuance/refresh, session
# management, role assignment (admin / staff / client), and token
# revocation. Every other service trusts tokens signed here.
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=4001

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection string for the auth schema
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/maphari?schema=auth_schema"

# ── JWT Secrets ───────────────────────────────────────────────────
# CRITICAL: JWT_ACCESS_SECRET MUST match JWT_ACCESS_SECRET in apps/gateway/.env
# If they differ, the gateway will reject every token the auth service issues.
#
# Generate a strong secret:  openssl rand -hex 32
# Minimum recommended length: 64 hex characters (256-bit entropy)
JWT_ACCESS_SECRET="replace-with-64-char-random-secret"

# How long an access token is valid (seconds).
# Default: 900 = 15 minutes. Shorter = more secure but more refresh calls.
ACCESS_TOKEN_TTL_SECONDS=900

# How many days a refresh token is stored in the database.
# Users who haven't logged in for this many days must log in again.
REFRESH_TOKEN_TTL_DAYS=7

# How many hours a single session (device) stays active after last use.
# Independent of REFRESH_TOKEN_TTL_DAYS — the shorter of the two wins.
REFRESH_TOKEN_SESSION_TTL_HOURS=24

# ── NATS ──────────────────────────────────────────────────────────
# Message bus for publishing auth events (user.registered, user.invited, etc.)
NATS_URL="nats://localhost:4222"

# ── Bootstrap / Seeding ───────────────────────────────────────────
# ADMIN_EMAILS: Comma-separated list of email addresses that receive the
# ADMIN role automatically when they register for the first time.
# Example (production):  "ceo@yourcompany.com,cto@yourcompany.com"
# WARNING: Any email in this list will get full admin access on first sign-up.
# Remove from this list BEFORE going to production if using invite-only onboarding.
ADMIN_EMAILS="mat.official@mapharitechnologies.com"

# STAFF_EMAILS: Comma-separated list of emails that receive the STAFF role
# automatically on first registration (e.g. internal team members).
# Example: "staff@mapharitechnologies.com,support@mapharitechnologies.com"
STAFF_EMAILS="ops@mapharitechnologies.com"

# Set to "true" to log bootstrap/seed activity on startup.
# Useful during initial deployment to verify roles were assigned correctly.
# Set to "false" in production to reduce log noise.
AUTH_BOOTSTRAP_LOGS="true"

# ── Google OAuth (optional) ───────────────────────────────────────
# OPTIONAL. Required only if Google sign-in is enabled.
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI must match GOOGLE_CALLBACK_URL exactly.
# GOOGLE_CLIENT_ID="replace-with-google-client-id"
# GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"
# GOOGLE_CALLBACK_URL="http://localhost:4001/auth/oauth/google/callback"

# ── TOTP / 2FA (optional) ─────────────────────────────────────────
# OPTIONAL. Required only if two-factor authentication (TOTP) is enabled.
# TOTP_ISSUER="Maphari"  # Label shown in authenticator apps (e.g. Google Authenticator)

# ── Security controls ─────────────────────────────────────────────
NODE_ENV="development"
SERVICE_RATE_LIMIT_PUBLIC_MAX=120
SERVICE_RATE_LIMIT_PROTECTED_MAX=240
SERVICE_RATE_LIMIT_WINDOW_MS=60000
