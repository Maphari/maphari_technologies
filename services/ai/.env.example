# ══════════════════════════════════════════════════════════════════
# services/ai — AI Service
# Handles: text generation, lead qualification, proposal drafting,
# project estimation, and AI action recommendations.
# Uses dual-provider strategy: OpenAI for speed-critical tasks,
# Anthropic Claude for deep reasoning tasks.
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
PORT=4007

# ── OpenAI ────────────────────────────────────────────────────────
# REQUIRED for: recommendations, lead qualification, standup summaries
# Get your key at: https://platform.openai.com/api-keys
# Model used: gpt-4o-mini (fast, cost-effective for structured tasks)
OPENAI_API_KEY="sk-proj-replace-with-your-openai-key"

# ── Anthropic (Claude) ────────────────────────────────────────────
# REQUIRED for: proposal drafting, complex project estimates
# Get your key at: https://console.anthropic.com/settings/keys
# Model used: claude-sonnet-4-5 (deep reasoning, long context)
ANTHROPIC_API_KEY="sk-ant-api03-replace-with-your-anthropic-key"

# ── Service Dependencies ──────────────────────────────────────────
# Core service URL — used to fetch health scores, projects, leads
# for AI recommendation analysis
CORE_SERVICE_URL="http://localhost:4002"
# Billing service URL — used to fetch invoice data for revenue analysis
BILLING_SERVICE_URL="http://localhost:4006"

# ── Security controls ─────────────────────────────────────────────
NODE_ENV="development"
SERVICE_RATE_LIMIT_PUBLIC_MAX=120
SERVICE_RATE_LIMIT_PROTECTED_MAX=240
SERVICE_RATE_LIMIT_WINDOW_MS=60000

# ── Prospecting ───────────────────────────────────────────────────────────────
# Outbound pitch emails come FROM this address (must be a verified Resend sender)
OUTREACH_FROM_EMAIL="Maphari Technologies <outreach@mapharitechnologies.com>"
# SerpAPI — Google Maps business search. Get key: https://serpapi.com/dashboard
SERPAPI_KEY="replace-with-your-serpapi-key"
# Hunter.io — email enrichment. Get key: https://hunter.io/api-keys
HUNTER_API_KEY="replace-with-your-hunter-api-key"
# Comma-separated admin emails for run-summary alerts
ADMIN_EMAILS="mat.official@mapharitechnologies.com"
# Resend API key for direct pitch email delivery
RESEND_API_KEY="replace-with-your-resend-api-key"
# Transactional notification emails (reports, alerts) come FROM this address
NOTIFICATION_FROM_EMAIL="Maphari <notifications@mapharitechnologies.com>"
# AI service base URL — used by auto-prospect script to call send-pitch endpoint
SERVICE_AI_BASE_URL="http://localhost:3003"
